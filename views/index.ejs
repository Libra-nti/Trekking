    <div id="content" >
      <div id="trekking-list" class="container">
        <div class="row" id="row-1"><% treks.forEach((trek, index) => {%> <div class="col-sm-4 col-lg-2 col-6 mb-3">
            <a href="/trekking/<%=trek.name%>" style="all: unset">
              <div class="card h-100" style="width: auto">
<% if (index == 1 || index == 2 || index == 3 || index == 4 || index == 5 || index == 6) { %>
        <%# Prima card: carica subito ad alta risoluzione, niente lazy %>
        <img
          fetchpriority="high"
          src="https://res.cloudinary.com/dieh3kepz/image/upload/w_400/<%=trek.name%>-<%=trek.date%>/copertina-400.jpg"
          srcset="
            https://res.cloudinary.com/dieh3kepz/image/upload/w_200/<%=trek.name%>-<%=trek.date%>/copertina-400.jpg 200w,
            https://res.cloudinary.com/dieh3kepz/image/upload/w_400/<%=trek.name%>-<%=trek.date%>/copertina-400.jpg 400w,
            https://res.cloudinary.com/dieh3kepz/image/upload/w_800/<%=trek.name%>-<%=trek.date%>/copertina-400.jpg 800w
          "
          sizes="(max-width: 576px) 50vw, (max-width: 992px) 33vw, 16vw"
          class="card-img-top"
          alt="Foto copertina-400 <%=trek.name%>"
        />
      <% } else { %>
        <%# Tutte le altre: placeholder sfocato + lazy load progressivo %>
        <img
          class="card-img-top lazy-progressive"
          src="https://res.cloudinary.com/dieh3kepz/image/upload/w_20,e_blur:200/<%=trek.name%>-<%=trek.date%>/copertina-400.jpg"
          data-src="https://res.cloudinary.com/dieh3kepz/image/upload/w_400/<%=trek.name%>-<%=trek.date%>/copertina-400.jpg"
          data-srcset="
            https://res.cloudinary.com/dieh3kepz/image/upload/w_200/<%=trek.name%>-<%=trek.date%>/copertina-400.jpg 200w,
            https://res.cloudinary.com/dieh3kepz/image/upload/w_400/<%=trek.name%>-<%=trek.date%>/copertina-400.jpg 400w,
            https://res.cloudinary.com/dieh3kepz/image/upload/w_800/<%=trek.name%>-<%=trek.date%>/copertina-400.jpg 800w
          "
          data-sizes="(max-width: 576px) 50vw, (max-width: 992px) 33vw, 16vw"
          alt="Foto copertina-400 <%=trek.name%>"
        />
      <% } %>               <div class="card-body bottom-0">
                  <h5 class="card-title"><%=trek.name%> </h5>
                  <div class="card-text">
                    <p><%=trek.date%></p>
                    <p class="hide-description" style="display: none;"><%=trek.description%></p>
                  </div>
                </div>
              </div>
            </a>
          </div><%});%>
        </div>
      </div>
